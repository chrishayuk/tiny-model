# Datasets are build artefacts, not source. Both trees regenerate from
# extractors; neither should live in git history.
datasets/raw/
datasets/extracted/
datasets/extracted-legacy/

# sample outputs
knowledge-extractor/examples/sample_output/

# bemchmarks
benchmarks/results/

# Keep the top-level placeholder so the tree structure is visible.
!datasets/.gitkeep

# Rust build output (tokenizer workspace + v11-python cdylib)
target/
**/target/
*.rlib
*.rmeta

# Python wheels and sdists from maturin
*.whl
*.tar.gz

# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
.pytest_cache/
dist/

# Python build output (setup.py / hatch). Unanchored so it catches
# `build/` at any depth. The v11 tokenizer's published HF bundle lives
# at `tokenizer/v11/artifacts/` for this reason — no collision here.
build/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/
.claude/

# artifacts
artifacts/
safetensors/
vindex/

# v12 tokenizer: generated corpora / trained candidates / eval output —
# tracked as real artifacts in the chuk-experiments server instead, not
# in git history. Scripts, pins, manifests, and README stay tracked.
tokenizer/v12/corpus/c8_corpus_v0.jsonl
tokenizer/v12/corpus/c8_corpus_v0.txt
tokenizer/v12/corpus/c8_code_corpus.jsonl
tokenizer/v12/training/candidates/
tokenizer/v12/training/candidates.jsonl
tokenizer/v12/bench/reports/
